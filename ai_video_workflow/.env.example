# Nano Banana Pro (Google Gemini API)
# 获取地址: https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Nano Banana 模型选择 (可选)
# gemini-3.1-flash-image-preview = Nano Banana 2 (推荐, 更快更便宜)
# gemini-3-pro-image-preview = Nano Banana Pro (更高质量, 2026-03-09 停用)
NANO_BANANA_MODEL=gemini-3.1-flash-image-preview

# SeedDance 2.0 (ModelsLab API)
# 获取地址: https://modelslab.com
MODELSLAB_API_KEY=your_modelslab_api_key_here

# 日志级别 (可选)
LOG_LEVEL=INFO
